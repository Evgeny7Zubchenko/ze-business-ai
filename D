    c = db()
    cur = c.cursor()
    cur.execute("DELETE FROM sites WHERE id=?", (sid,))
    cur.execute("DELETE FROM leads WHERE site_id=?", (sid,))
    cur.execute("DELETE FROM views WHERE site_id=?", (sid,))
    c.commit()
